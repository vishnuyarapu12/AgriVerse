# Farmer Advisory API Environment Configuration
# Copy this file to .env and fill in your actual values

# Gemini AI API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-pro

# API Configuration
API_HOST=localhost
API_PORT=8000
DEBUG=true

# Database Configuration (if using database in future)
DATABASE_URL=sqlite:///./agriverse.db

# Security Configuration
SECRET_KEY=your-secret-key-here-generate-a-strong-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Voice Services Configuration
ENABLE_VOICE_INPUT=true
ENABLE_VOICE_OUTPUT=true
TTS_SERVICE=gtts  # Options: gtts, pyttsx3

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/agriverse.log

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# External APIs (Optional)
WEATHER_API_KEY=your_weather_api_key
MARKET_API_KEY=your_market_data_api_key